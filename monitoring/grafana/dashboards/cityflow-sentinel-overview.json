{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "🚀 Performance KPIs",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#00BCD4", "mode": "fixed" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#00BCD4", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 1 },
      "id": 10,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(http_requests_total{handler=\"/predict\"}) or vector(0)",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Total Predictions",
      "description": "Total map-click predictions made this session",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#00BCD4", "value": null },
              { "color": "#00BCD4", "value": 0 },
              { "color": "#FFE44B", "value": 15 },
              { "color": "#FF5722", "value": 30 }
            ]
          },
          "unit": "s",
          "decimals": 1
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 1 },
      "id": 11,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_sum{handler=~\"/chat.*\"}[5m])) / clamp_min(sum(rate(http_request_duration_seconds_count{handler=~\"/chat.*\"}[5m])), 1e-10)",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Avg Chat Response Time",
      "description": "Average RAG assistant latency. Green < 15s, Yellow < 30s, Red > 30s",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "#00BCD4", "mode": "fixed" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#00BCD4", "value": null }] },
          "unit": "s",
          "decimals": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 1 },
      "id": 12,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "time() - process_start_time_seconds{job=\"fastapi-backend\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "System Uptime",
      "description": "Total time the CityFlow Sentinel backend has been live",
      "type": "stat"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "id": 200,
      "title": "🧠 AI Model Metrics",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 25,
            "gradientMode": "scheme",
            "showPoints": "auto",
            "pointSize": 5
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "id": 20,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_sum{handler=~\"/chat.*\"}[1m])) / clamp_min(sum(rate(http_request_duration_seconds_count{handler=~\"/chat.*\"}[1m])), 1e-10)",
          "legendFormat": "avg /chat latency",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{handler=~\"/chat.*\"}[5m])) by (le))",
          "legendFormat": "p95 /chat latency",
          "refId": "B"
        }
      ],
      "title": "Chat Latency (Llama-3 RAG)",
      "description": "Average and P95 response time of the Llama-3 RAG pipeline",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-GrYlRd" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#00BCD4", "value": null },
              { "color": "#00BCD4", "value": 0 },
              { "color": "#FFE44B", "value": 40 },
              { "color": "#FF9800", "value": 60 },
              { "color": "#FF5722", "value": 80 }
            ]
          },
          "min": 0,
          "max": 100,
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "id": 21,
      "options": {
        "displayMode": "gradient",
        "minVizHeight": 10,
        "minVizWidth": 0,
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true,
        "valueMode": "color"
      },
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_sum{handler=\"/predict\"}[5m])) / clamp_min(sum(rate(http_request_duration_seconds_count{handler=\"/predict\"}[5m])), 1e-10) * 100",
          "legendFormat": "Avg Tension Score",
          "refId": "A",
          "instant": true
        }
      ],
      "title": "Tension Score Distribution",
      "description": "Distribution of predicted urban stress levels across map selections. Proves the model generates varied results, not a single static number.",
      "type": "bargauge"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "mappings": [],
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Successful (2xx)" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#00BCD4", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Errors (4xx/5xx)" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#FF5722", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 },
      "id": 22,
      "options": {
        "displayLabels": ["percent"],
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "values": ["value", "percent"] },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "expr": "sum(http_requests_total{status=~\"2..\"}) or vector(0)",
          "legendFormat": "Successful (2xx)",
          "refId": "A",
          "instant": true
        },
        {
          "expr": "sum(http_requests_total{status=~\"4..|5..\"}) or vector(0)",
          "legendFormat": "Errors (4xx/5xx)",
          "refId": "B",
          "instant": true
        }
      ],
      "title": "RAG Success vs Error Ratio",
      "description": "Visualizes the reliability of our RAG pipeline. A 99% teal circle represents a production-ready assistant.",
      "type": "piechart"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 15 },
      "id": 23,
      "options": {
        "legend": { "calcs": ["mean"], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{handler=\"/predict\"}[1m]))",
          "legendFormat": "/predict req/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_requests_total{handler=~\"/chat.*\"}[1m]))",
          "legendFormat": "/chat req/s",
          "refId": "B"
        }
      ],
      "title": "Request Throughput",
      "description": "Live request rate for prediction and chat endpoints",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
