      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 },
      "id": 24,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"4..|5..\"}[1m]))",
          "legendFormat": "4xx/5xx errors",
          "refId": "A"
        }
      ],
      "title": "Error Rate Timeline",
